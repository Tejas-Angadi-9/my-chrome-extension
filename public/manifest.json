{
  "manifest_version": 3,
  "name": "React Chrome Extension",
  "version": "1.0.0",
  "description": "A simple react app as chrome extension",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": ["tabs", "activeTab", "storage", "scripting"],
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "type": "module"
    }
  ],
  "host_permissions": ["*://*/*"]
}
